# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
#
# Patterns are intentionally NOT root-anchored so they match under apps/* and packages/*
# (e.g. apps/blog/.next, packages/ui/dist).

# dependencies
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
pnpm-store/
.corepack/

# build output
.next/
out/
build/
dist/

# testing
coverage/

# misc
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (opt-in commit per app if ever needed)
.env*

# vercel
.vercel

# claude code (per-user overrides)
.claude/settings.local.json

# typescript
*.tsbuildinfo
next-env.d.ts
