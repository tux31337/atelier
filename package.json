{
  "name": "atelier",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm -F @atelier/blog dev",
    "build": "pnpm -r build",
    "start": "pnpm -F @atelier/blog start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "docker:blog:build": "docker build -f apps/blog/Dockerfile -t atelier-blog:test .",
    "docker:blog:up": "docker compose up --build blog",
    "docker:blog:down": "docker compose down"
  }
}
